---
export const title = "Lorem Ipsum";

import Layout from "../layouts/Layout.astro";
import projects from "../../public/projects.json";
import artworks from "../../public/artworks.json";

const allPosts = Object.values(import.meta.glob("./posts/*.mdx", { eager: true }));
const publishedPosts = allPosts.filter(
    (post) => post.frontmatter?.published !== false
);

const allNotes = Object.values(import.meta.glob("./notes/*.mdx", { eager: true }));
const publishedNotes = allNotes.filter(
    (note) => note.frontmatter?.published !== false
);

const appPages = Object.keys(import.meta.glob("./apps/*.astro"));
const appCount = appPages.filter((page) => !page.endsWith("/index.astro")).length;

const pickByTitle = (items, titles) =>
    titles
        .map((title) =>
            items.find((item) => item.title === title || item.frontmatter?.title === title)
