                                            {angle}
                                        </p>
                                    </div>
                                </div>
                                {
                                    project.technologies?.length > 0 && (
                                        <div class="flex flex-wrap gap-2">
                                            {project.technologies.map((technology) => (
                                                <span class="rounded-sm border border-gray-300 px-2 py-1 text-xs font-medium text-gray-700">
                                                    {technology}
                                                </span>
                                            ))}
                                        </div>
                                    )
                                }
                                {
                                    project.links?.length > 0 && (
                                        <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
                                            {project.links.map((link) => (
                                                <a
                                                    href={link.url}
                                                    target={link.url.startsWith("http")
                                                        ? "_blank"
                                                        : undefined}
                                                    rel={link.url.startsWith("http")
                                                        ? "noopener noreferrer"
                                                        : undefined}
                                                    class="font-medium text-gray-900 underline decoration-gray-300 underline-offset-4 transition-colors hover:decoration-gray-900"
                                                >
                                                    {link.name}
                                                </a>
                                            ))}
                                        </div>
